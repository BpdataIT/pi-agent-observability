{
  "_instructions": "Factory Droid hooks config. INSTALL INTO ~/.factory/settings.json under the hooks key (just droid-install). Also writes ~/.factory/hooks.json as reference. Replace /ABS/PATH with the absolute path to your pi-agent-observability clone. Use full bun path (e.g. /opt/homebrew/bin/bun). Remove this _instructions key before use.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "bun /ABS/PATH/integrations/droid/obs-hook.ts" }
        ]
      }
    ]
  }
}
